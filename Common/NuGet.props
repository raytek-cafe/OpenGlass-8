<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <!--
    Common NuGet .props imports used by native projects in this repo.

    Import this near the top of a .vcxproj (right after <Project ...>),
    before Microsoft.Cpp.Default.props.

    NOTE: Relative paths here are resolved from the location of this file (Common\).
  -->

  <Import Project="..\packages\VC-LTL.5.3.1\build\native\VC-LTL.props"
          Condition="Exists('..\packages\VC-LTL.5.3.1\build\native\VC-LTL.props')" />
  <Import Project="..\packages\YY.NuGet.Import.Helper.1.0.2\build\native\YY.NuGet.Import.Helper.props"
          Condition="Exists('..\packages\YY.NuGet.Import.Helper.1.0.2\build\native\YY.NuGet.Import.Helper.props')" />

  <Import Project="..\packages\Microsoft.SourceLink.GitHub.10.0.102\build\Microsoft.SourceLink.GitHub.props"
          Condition="Exists('..\packages\Microsoft.SourceLink.GitHub.10.0.102\build\Microsoft.SourceLink.GitHub.props')" />
  <Import Project="..\packages\Microsoft.SourceLink.Common.10.0.102\build\Microsoft.SourceLink.Common.props"
          Condition="Exists('..\packages\Microsoft.SourceLink.Common.10.0.102\build\Microsoft.SourceLink.Common.props')" />
  <Import Project="..\packages\Microsoft.Build.Tasks.Git.10.0.102\build\Microsoft.Build.Tasks.Git.props"
          Condition="Exists('..\packages\Microsoft.Build.Tasks.Git.10.0.102\build\Microsoft.Build.Tasks.Git.props')" />
</Project>
