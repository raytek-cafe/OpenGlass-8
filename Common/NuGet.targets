<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <!--
    Common NuGet .targets imports used by native projects in this repo.

    Import this from a .vcxproj inside ImportGroup Label="ExtensionTargets".

    NOTE: Relative paths here are resolved from the location of this file (Common\).
  -->

  <Import Project="..\packages\Microsoft.Build.Tasks.Git.10.0.102\build\Microsoft.Build.Tasks.Git.targets"
          Condition="Exists('..\packages\Microsoft.Build.Tasks.Git.10.0.102\build\Microsoft.Build.Tasks.Git.targets')" />
  <Import Project="..\packages\Microsoft.SourceLink.Common.10.0.102\build\Microsoft.SourceLink.Common.targets"
          Condition="Exists('..\packages\Microsoft.SourceLink.Common.10.0.102\build\Microsoft.SourceLink.Common.targets')" />
  <Import Project="..\packages\Microsoft.SourceLink.GitHub.10.0.102\build\Microsoft.SourceLink.GitHub.targets"
          Condition="Exists('..\packages\Microsoft.SourceLink.GitHub.10.0.102\build\Microsoft.SourceLink.GitHub.targets')" />

  <Import Project="..\packages\YY.NuGet.Import.Helper.1.0.2\build\native\YY.NuGet.Import.Helper.targets"
          Condition="Exists('..\packages\YY.NuGet.Import.Helper.1.0.2\build\native\YY.NuGet.Import.Helper.targets')" />

  <PropertyGroup>
    <!-- If true, and NuGetPackageBuildImports is not set, we'll validate a default list for this repo. -->
    <NuGetEnableDefaultBuildImportValidation Condition="'$(NuGetEnableDefaultBuildImportValidation)'==''">true</NuGetEnableDefaultBuildImportValidation>
  </PropertyGroup>

  <!-- Default import list for this repo (absolute paths to avoid ambiguous relative resolution). -->
  <ItemGroup>
    <_NuGetDefaultBuildImport Include="$(MSBuildThisFileDirectory)..\packages\Microsoft.Build.Tasks.Git.10.0.102\build\Microsoft.Build.Tasks.Git.props" />
    <_NuGetDefaultBuildImport Include="$(MSBuildThisFileDirectory)..\packages\Microsoft.Build.Tasks.Git.10.0.102\build\Microsoft.Build.Tasks.Git.targets" />
    <_NuGetDefaultBuildImport Include="$(MSBuildThisFileDirectory)..\packages\Microsoft.SourceLink.Common.10.0.102\build\Microsoft.SourceLink.Common.props" />
    <_NuGetDefaultBuildImport Include="$(MSBuildThisFileDirectory)..\packages\Microsoft.SourceLink.Common.10.0.102\build\Microsoft.SourceLink.Common.targets" />
    <_NuGetDefaultBuildImport Include="$(MSBuildThisFileDirectory)..\packages\Microsoft.SourceLink.GitHub.10.0.102\build\Microsoft.SourceLink.GitHub.props" />
    <_NuGetDefaultBuildImport Include="$(MSBuildThisFileDirectory)..\packages\Microsoft.SourceLink.GitHub.10.0.102\build\Microsoft.SourceLink.GitHub.targets" />
    <_NuGetDefaultBuildImport Include="$(MSBuildThisFileDirectory)..\packages\YY.NuGet.Import.Helper.1.0.2\build\native\YY.NuGet.Import.Helper.props" />
    <_NuGetDefaultBuildImport Include="$(MSBuildThisFileDirectory)..\packages\YY.NuGet.Import.Helper.1.0.2\build\native\YY.NuGet.Import.Helper.targets" />
    <_NuGetDefaultBuildImport Include="$(MSBuildThisFileDirectory)..\packages\VC-LTL.5.3.1\build\native\VC-LTL.props" />
  </ItemGroup>

  <PropertyGroup Condition="'$(NuGetEnableDefaultBuildImportValidation)'=='true' and '$(NuGetPackageBuildImports)'==''">
    <NuGetPackageBuildImports>@(_NuGetDefaultBuildImport,';')</NuGetPackageBuildImports>
  </PropertyGroup>

  <!--
    Optional: projects can provide a semicolon-separated list of files to validate existence.

    Or simply set NuGetEnableDefaultBuildImportValidation=true to validate this repo's default list.
  -->
  <Target Name="EnsureNuGetPackageBuildImports" BeforeTargets="PrepareForBuild" Condition="'$(NuGetPackageBuildImports)'!=''">
    <PropertyGroup>
      <NuGetPackageBuildImports_ErrorText Condition="'$(NuGetPackageBuildImports_ErrorText)'==''">This project references NuGet package(s) that are missing on this computer. Use NuGet Package Restore to download them.  For more information, see http://go.microsoft.com/fwlink/?LinkID=322105. The missing file is {0}.</NuGetPackageBuildImports_ErrorText>
    </PropertyGroup>
    <ItemGroup>
      <NuGetPackageBuildImport Include="$(NuGetPackageBuildImports)" />
    </ItemGroup>
    <Error Condition="!Exists('%(NuGetPackageBuildImport.Identity)')" Text="$([System.String]::Format('$(NuGetPackageBuildImports_ErrorText)', '%(NuGetPackageBuildImport.Identity)'))" />
  </Target>
</Project>
